@model IPNoticeHub.Web.Models.PdfGeneration.CeaseDesistViewModel

@{
    ViewData["Title"] = "Edit Cease & Desist";
    Layout = "_Layout";
}

<style>
    .a4-frame {
        display: flex;
        justify-content: center;
        padding: 24px;
    }

    .a4-paper {
        width: 210mm;
        height: 297mm;
        background: #fff;
        color: #222;
        box-shadow: 0 10px 30px rgba(0,0,0,0.06);
        border-radius: 8px;
        padding: 20mm;
        overflow: auto;
        line-height: 1.6;
        font-family: Georgia, "Times New Roman", serif;
        font-size: 12pt;
        white-space: pre-wrap;
    }

        .a4-paper b,
        .a4-paper strong {
            font-weight: 700;
        }
</style>

<div class="container py-4">
    <h2>Edit Cease &amp; Desist</h2>

    <div class="a4-frame">
        <textarea asp-for="BodyTemplate" class="a4-paper" id="BodyTemplate"></textarea>
    </div>

    <textarea id="OriginalBodyTemplate" class="d-none">@Model.BodyTemplate</textarea>

    <div class="mt-3 d-flex flex-wrap gap-2 justify-content-center">

        <form asp-action="CeaseDesist" method="post" id="generateForm" class="d-inline">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="PublicId" />
            <input type="hidden" asp-for="SenderName" />
            <input type="hidden" asp-for="SenderAddress" />
            <input type="hidden" asp-for="SenderEmail" />
            <input type="hidden" asp-for="RecipientName" />
            <input type="hidden" asp-for="RecipientAddress" />
            <input type="hidden" asp-for="RecipientEmail" />
            <input type="hidden" asp-for="InfringingUrl" />
            <input type="hidden" asp-for="WorkTitle" />
            <input type="hidden" asp-for="RegistrationNumber" />
            <input type="hidden" asp-for="AdditionalFacts" />

            <input type="hidden" asp-for="BodyTemplate" id="BodyTemplatePdf" />

            <button type="submit" class="btn btn-secondary">
                Generate PDF
            </button>
        </form>

        <form asp-action="CeaseDesistEdit" method="post" id="editForm" class="d-inline">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="PublicId" />
            <input type="hidden" asp-for="SenderName" />
            <input type="hidden" asp-for="SenderAddress" />
            <input type="hidden" asp-for="SenderEmail" />
            <input type="hidden" asp-for="RecipientName" />
            <input type="hidden" asp-for="RecipientAddress" />
            <input type="hidden" asp-for="RecipientEmail" />
            <input type="hidden" asp-for="InfringingUrl" />
            <input type="hidden" asp-for="WorkTitle" />
            <input type="hidden" asp-for="RegistrationNumber" />
            <input type="hidden" asp-for="AdditionalFacts" />

            <input type="hidden" asp-for="BodyTemplate" id="BodyTemplateEdit" />

            <button type="button" class="btn btn-danger" id="btnReset">
                Reset
            </button>

            <button type="submit" name="command" value="save" class="btn btn-primary">
                Save
            </button>

            <button type="submit" name="command" value="done" class="btn btn-outline-secondary">
                Done
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const editor   = document.getElementById('BodyTemplate');
            const original = document.getElementById('OriginalBodyTemplate');
            const pdfBody  = document.getElementById('BodyTemplatePdf');
            const editBody = document.getElementById('BodyTemplateEdit');

            document.getElementById('btnReset')
                .addEventListener('click', function () {
                    editor.value = original.value;
                });

            document.getElementById('generateForm')
                .addEventListener('submit', function () {
                    pdfBody.value = editor.value;
                });

            document.getElementById('editForm')
                .addEventListener('submit', function () {
                    editBody.value = editor.value;
                });
        })();
    </script>
}
