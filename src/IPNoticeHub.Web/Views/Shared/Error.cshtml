@using IPNoticeHub.Web.Models.Errors
@model ErrorViewModel
@{
    ViewData["Title"] = "Unexpected error";
    Layout = "_Layout";
}

<main class="py-4">
    <div class="container">
        <h1 class="display-5 mb-3 text-danger">Something went wrong</h1>
        <p class="lead">
            An unexpected error occurred while processing your request.
        </p>

        @if (Model.ShowRequestId)
        {
            <p class="text-muted">
                <strong>Request ID:</strong> <code>@Model.RequestId</code>
            </p>
        }

        <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">
            ← Back to home
        </a>
    </div>
</main>
