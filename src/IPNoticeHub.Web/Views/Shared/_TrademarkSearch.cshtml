@using System.ComponentModel.DataAnnotations
@using IPNoticeHub.Shared.Enums;
@{
    var classNumbers = Enum.GetValues(typeof(TrademarkClass)).Cast<TrademarkClass>();
    var statusItems = Enum.GetValues(typeof(TrademarkStatusCategory)).Cast<TrademarkStatusCategory>();
    var searchByItems = Enum.GetValues(typeof(TrademarkSearchBy)).Cast<TrademarkSearchBy>();
    var officeItems = Enum.GetValues(typeof(DataProvider)).Cast<DataProvider>();
    var searchModeItems = Enum.GetValues(typeof(SearchMode)).Cast<SearchMode>();

    string? searchQuery = Context.Request.Query["trademark"].FirstOrDefault();
    string? classNumberFilter = Context.Request.Query["classNumber"].FirstOrDefault();
    string? statusFilter = Context.Request.Query["status"].FirstOrDefault();
    string? searchByFilter = Context.Request.Query["searchByItem"].FirstOrDefault();
    string? officeFilter = Context.Request.Query["office"].FirstOrDefault();
    string? modeFilter = Context.Request.Query["mode"].FirstOrDefault();
}

<section class="py-5">
    <div class="container">

        <!-- Search Form -->
        <div class="text-center mb-4">
            <h1 class="h3 mb-3">Search Trademarks</h1>

            <form id="trademarkSearchForm"
                  method="get"
                  asp-controller="Home"
                  asp-action="Results"
                  class="d-flex justify-content-center">
                <div class="input-group input-group-lg" style="max-width: 820px;">
                    <input name="trademark"
                           value="@searchQuery"
                           class="form-control"
                           type="search"
                           placeholder="Enter mark, owner, or reg. no."
                           aria-label="Search trademarks" />
                    <button class="btn btn-primary" type="submit">Search</button>
                </div>
            </form>

            <div class="text-muted small mt-2">
                Search for trademark wordmarks, registration number, or owners
            </div>
        </div>

        @functions {
            string GetDisplayName(Enum value)
            {
                var member = value.GetType().GetMember(value.ToString()).First();
                var display = member.GetCustomAttributes(typeof(DisplayAttribute), false)
                                    .OfType<DisplayAttribute>()
                                    .FirstOrDefault();
                return display?.Name ?? value.ToString();
            }
        }

        <!-- Filters -->
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="row g-3">

                    <!-- Search By Trademark Filter -->
                    <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label" for="f-searchByItem">Search By</label>
                        <select id="f-searchByItem"
                                name="searchByItem"
                                class="form-select"
                                form="trademarkSearchForm">
                            @foreach (var searchByItem in searchByItems)
                            {
                                var optionIsSelected =
                                    (!Context.Request.Query.ContainsKey("searchByItem") &&
                                     searchByItem == TrademarkSearchBy.Wordmark)
                                    || (searchByFilter == searchByItem.ToString());

                                <option value="@searchByItem" selected="@(optionIsSelected)">
                                    @GetDisplayName(searchByItem)
                                </option>
                            }
                        </select>
                    </div>

                    <!-- Trademark Status Filter -->
                    <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label" for="f-status">Trademark Status</label>
                        <select id="f-status"
                                name="status"
                                class="form-select"
                                form="trademarkSearchForm">
                            <option value="">Any</option>
                            @foreach (var status in statusItems)
                            {
                                <option value="@status" selected="@(statusFilter == status.ToString())">
                                    @GetDisplayName(status)
                                </option>
                            }
                        </select>
                    </div>

                    <!-- Trademark Class Numbers Filter -->
                    <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label" for="f-classNumber">Class Numbers</label>
                        <select id="f-classNumber"
                                name="classNumber"
                                class="form-select"
                                form="trademarkSearchForm">
                            <option value="">All classes</option>
                            @foreach (var classNumber in classNumbers)
                            {
                                <option value="@classNumber"
                                        selected="@(classNumberFilter == classNumber.ToString())">
                                    @GetDisplayName(classNumber)
                                </option>
                            }
                        </select>
                    </div>

                    <!-- Trademark Registration Office Filter -->
                    <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label" for="f-office">Registration Office</label>
                        <select id="f-office"
                                name="office"
                                class="form-select"
                                form="trademarkSearchForm">
                            <option value="">Any</option>
                            @foreach (var office in officeItems)
                            {
                                <option value="@office" selected="@(officeFilter == office.ToString())">
                                    @office
                                </option>
                            }
                        </select>
                    </div>

                    <!-- Trademark Search Mode Filter -->
                    <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label" for="f-mode">Search Mode</label>
                        <select id="f-mode"
                                name="mode"
                                class="form-select"
                                form="trademarkSearchForm">
                            <option value="">Any</option>
                            @foreach (var mode in searchModeItems)
                            {
                                <option value="@mode" selected="@(modeFilter == mode.ToString())">
                                    @mode
                                </option>
                            }
                        </select>
                    </div>

                    <!-- Buttons -->
                    <div class="col-12 col-lg-4 d-flex align-items-end">
                        <a class="btn btn-outline-secondary"
                           asp-controller="Home"
                           asp-action="Index">
                            Clear
                        </a>
                    </div>

                </div>
            </div>
        </div>

    </div>
</section>
