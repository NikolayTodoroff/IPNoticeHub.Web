@using IPNoticeHub.Web.Models.TrademarkSearch
@model TrademarkSearchResultsViewModel

@{
    ViewData["Title"] = "Search Results";
    Layout = "_Layout";

    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

<main class="py-4">
    @await Html.PartialAsync("_TrademarkSearch")

    <div class="container mt-4">
        @if (Model is not null)
        {
            @await Html.PartialAsync(
            "_TrademarkSearchResults",
                Model,
                new ViewDataDictionary(ViewData) { ["ReturnUrl"] = returnUrl }
                )
                }
        else
        {
            <div class="alert alert-info">
                Enter a query above to see results.
            </div>
        }
    </div>
</main>
