@using static IPNoticeHub.Web.Infrastructure.EnumExtensions;
@model IReadOnlyList<IPNoticeHub.Services.DocumentLibrary.DTOs.DocumentListItemDto>

@{
    ViewData["Title"] = "Document Library";
}

<style>
.rename-btn {
    text-decoration: none !important;
    box-shadow: none !important;
}

.rename-btn:hover,
.rename-btn:focus {
    text-decoration: none !important;
    box-shadow: none !important;
}
</style>

<div class="container py-4">
    <h2>Document Library</h2>

    @if (TempData["ErrorMessage"] is string error)
    {
        <div class="alert alert-danger">@error</div>
    }

    @if (!Model.Any())
    {
        <p class="mt-3">You have no saved documents yet.</p>
    }
    else
    {
        <table class="table table-striped mt-3">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Type</th>
                    <th>Source</th>
                    <th>IP Title</th>
                    <th>Reg. No.</th>
                    <th>Created On</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var doc in Model)
                {
                    <tr>
                        <td class="align-middle">
                            <form asp-action="Rename"
                                  method="post"
                                  class="d-flex align-items-center mb-0 w-100">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@doc.Id" />

                                <button type="button"
                                        class="btn btn-link p-0 me-2 rename-btn"
                                        title="Rename document"
                                        onclick="focusTitleInput(this);">
                                    <span class="fs-5">✏️</span>
                                </button>

                                <input type="text"
                                       name="newTitle"
                                       value="@doc.DocumentTitle"
                                       class="form-control form-control-plaintext flex-grow-1"
                                       style="min-width: 260px;"
                                       onkeydown="submitOnEnter(event, this);" />

                            </form>
                        </td>

                        <td class="align-middle">@doc.TemplateType.GetDisplayName()</td>
                        <td class="align-middle">@doc.SourceType</td>
                        <td class="align-middle">@doc.IpTitle</td>
                        <td class="align-middle">@doc.RegistrationNumber</td>
                        <td class="align-middle">@doc.CreatedOn.ToString("yyyy-MM-dd")</td>

                        <td class="text-end align-middle">

                            <form asp-action="Generate" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@doc.Id" />
                                <button type="submit" class="btn btn-sm btn-primary me-1">
                                    Generate
                                </button>
                            </form>

                            <form asp-action="Edit"
                                  asp-controller="DocumentLibrary"
                                  method="get"
                                  class="d-inline ms-1 mb-0">
                                <input type="hidden" name="id" value="@doc.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    Edit
                                </button>
                            </form>

                            <form asp-action="Delete" method="post" class="d-inline ms-1 mb-0">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@doc.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<script>
    function focusTitleInput(button) {
        const input = button.closest("form").querySelector("input[name='newTitle']");
        if (input) {
            input.focus();
            input.select();
        }
    }

    function submitOnEnter(event, input) {
        if (event.key === "Enter") {
            event.preventDefault();
            input.closest("form").submit();
        }
    }
</script>

