@using System.ComponentModel.DataAnnotations
@using IPNoticeHub.Common.EnumConstants;
@{
    ViewData["Title"] = "Search";
    Layout = "_Layout";

    var classNumbers = Enum.GetValues(typeof(TrademarkClass)).Cast<TrademarkClass>();
    var statusItems = Enum.GetValues(typeof(TrademarkStatusCategory)).Cast<TrademarkStatusCategory>();
    var searchByItems = Enum.GetValues(typeof(TrademarkSearchBy)).Cast<TrademarkSearchBy>();
    var officeItems = Enum.GetValues(typeof(DataProvider)).Cast<DataProvider>();
    var searchModeItems = Enum.GetValues(typeof(SearchMode)).Cast<SearchMode>();

    string searchQuery = Context.Request.Query["tmQuery"];
    string classNumberFilter = Context.Request.Query["tmClass"];
    string statusFilter = Context.Request.Query["tmStatus"];
    string searchByFilter = Context.Request.Query["tmSearchItem"];
    string officeFilter = Context.Request.Query["tmOffice"];
    string modeFilter = Context.Request.Query["tmMode"];
}

<section class="py-5">
  <div class="container">

    <!-- Search hero -->
    <div class="text-center mb-4">
      <h1 class="h3 mb-3">Search Trademarks</h1>
      <!-- Submit to Trademarks/Index (results page) -->
      <form method="get" asp-controller="Trademarks" asp-action="Index" class="d-flex justify-content-center">
        <div class="input-group input-group-lg" style="max-width: 820px;">
          <input name="tmQuery" value="@searchQuery"
           class="form-control" type="search"
           placeholder="Enter mark, owner, or reg. no." aria-label="Search trademarks" />
          <button class="btn btn-primary" type="submit">Search</button>
        </div>
      </form>
      <div class="text-muted small mt-2">
        Search for trademark wordmarks, registration number, or owners
      </div>
    </div>

    <!-- Filters -->
    <div class="card shadow-sm">
      <div class="card-body">
        <form method="get" asp-controller="Trademarks" asp-action="Index">
          <div class="row g-3">
            <!-- Search By Trademark Filter -->
            <div class="col-12 col-md-6 col-lg-4">
              <label class="form-label" for="f-tmSearchItem">Search By</label>
              <select id="f-tmSearchItem" name="tmSearchItem" class="form-select">
                @foreach (var searchByItem in searchByItems)
                {
                         var optionIsSelected =
                         (!Context.Request.Query.ContainsKey("tmSearchItem") && searchByItem == TrademarkSearchBy.Wordmark)
                         || (searchByFilter == searchByItem.ToString());

                         <option value="@searchByItem" selected="@(optionIsSelected)">
                             @searchByItem
                         </option>
                }
              </select>
          </div>

            <!-- Trademark Status Filter -->
            <div class="col-12 col-md-6 col-lg-4">
              <label class="form-label" for="f-tmStatus">Trademark Status</label>
              <select id="f-tmStatus" name="tmStatus" class="form-select">
                <option value="">All</option>
                @foreach (var statusItem in statusItems)
                {
                        <option value="@statusItem" selected="@(statusFilter == statusItem.ToString())">
                            @statusItem
                        </option>
                }
              </select>
            </div>

            <!-- Trademark Class Numbers Filter -->
            <div class="col-12 col-md-6 col-lg-4">
              <label class="form-label" for="f-tmClass">Class Numbers</label>
              <select id="f-tmClass" name="tmClass" class="form-select">
                <option value="">All classes</option>
                @foreach (var classNumber in classNumbers)
                {
                        <option value="@classNumber"
                            selected="@(classNumberFilter == classNumber.ToString())">
                            @DisplayClassNumberNames(classNumber)
                        </option>
                }
              </select>
            </div>

            @functions 
            {
              string DisplayClassNumberNames(Enum value)
              {
                 var member = value.GetType().GetMember(value.ToString()).First();

                 var display = member.GetCustomAttributes(typeof(DisplayAttribute), false)
                 .OfType<DisplayAttribute>().FirstOrDefault();

                 return display?.Name ?? value.ToString();
              }
            }


            <!-- Trademark Registration Office Filter -->
            <div class="col-12 col-md-6 col-lg-4">
              <label class="form-label" for="f-tmOffice">Registration Office</label>
              <select id="f-tmOffice" name="tmOffice" class="form-select">
                <option value="">Any</option>
                @foreach (var office in officeItems)
                {
                       <option value="@office" selected="@(officeFilter == office.ToString())">@office</option>
                }
              </select>
            </div>

            <!-- Trademark Search Mode Filter -->
            <div class="col-12 col-md-6 col-lg-4">
              <label class="form-label" for="f-tmMode">Search Mode</label>
              <select id="f-tmMode" name="tmMode" class="form-select">
                <option value="">Any</option>
                @foreach (var mode in searchModeItems)
                {
                       <option value="@mode" selected="@(modeFilter == mode.ToString())">
                           @DisplaySearchModeNames(mode)
                       </option>
                }
              </select>
            </div>

            @functions 
            {
               string DisplaySearchModeNames(Enum value)
               {
               var member = value.GetType().GetMember(value.ToString()).First();

                  var display = member.GetCustomAttributes(typeof(DisplayAttribute), false)
                  .OfType<DisplayAttribute>().FirstOrDefault();

                  return display?.Name ?? value.ToString();
               }
            }

            <div class="col-12 col-lg-4 d-flex align-items-end">
              <button class="btn btn-outline-secondary me-2" type="reset">Clear</button>
              <button class="btn btn-primary" type="submit">Apply</button>
            </div>
          </div>
        </form>
      </div>
    </div>

  </div>
</section>
