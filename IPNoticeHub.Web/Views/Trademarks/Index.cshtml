@using IPNoticeHub.Common.EnumConstants;
@{
    ViewData["Title"] = "Search";
    Layout = "_Layout";

    var classNumbers = Enum.GetValues(typeof(TrademarkClass)).Cast<TrademarkClass>();
    var statusItems = Enum.GetValues(typeof(TrademarkStatusCategory)).Cast<TrademarkStatusCategory>();
    var searchByItems = Enum.GetValues(typeof(TrademarkSearchBy)).Cast<TrademarkSearchBy>();
    var officeItems = Enum.GetValues(typeof(DataProvider)).Cast<DataProvider>();
    var modeItems = new[] { "Identical", "Contains" };
    // Preserve query values on return navigation (nice UX)
    string q = Context.Request.Query["q"];
    string cls = Context.Request.Query["class"];
    string status = Context.Request.Query["status"];
    string by = Context.Request.Query["by"];
    string office = Context.Request.Query["office"];
    string mode = Context.Request.Query["mode"];
}

<section class="py-5">
  <div class="container">

    <!-- Search hero -->
    <div class="text-center mb-4">
      <h1 class="h3 mb-3">Search trademarks</h1>
      <!-- Submit to Trademarks/Index (results page) -->
      <form method="get" asp-controller="Trademarks" asp-action="Index" class="d-flex justify-content-center">
        <div class="input-group input-group-lg" style="max-width: 820px;">
          <input name="q" value="@q"
                 class="form-control" type="search"
                 placeholder="Enter mark, owner, or reg. no." aria-label="Search trademarks" />
          <button class="btn btn-primary" type="submit">Search</button>
        </div>
      </form>
      <div class="text-muted small mt-2">
        Type a mark, owner name, or registration number. We’ll wire advanced logic next.
      </div>
    </div>

    <!-- Filters -->
    <div class="card shadow-sm">
      <div class="card-body">
        <form method="get" asp-controller="Trademarks" asp-action="Index">
          <div class="row g-3">
            <!-- Search By -->
            <div class="col-12 col-md-6 col-lg-4">
              <label class="form-label" for="f-by">Search By</label>
              <select id="f-by" name="by" class="form-select">
                <option value="">Trademark</option>
                @foreach (var b in searchByItems)
                {
                        <option value="@b" selected="@(by == b.ToString())">
                            @b
                        </option>
                }
              </select>
          </div>

                        <!-- Trademark Status -->
            <div class="col-12 col-md-6 col-lg-4">
              <label class="form-label" for="f-status">Trademark Status</label>
              <select id="f-status" name="status" class="form-select">
                <option value="">All</option>
                @foreach (var s in statusItems)
                {
                        // Display: Pending, Registered, Canceled, Abandoned (enum names should match)
                        <option value="@s" selected="@(status == s.ToString())">
                            @s
                        </option>
                }
              </select>
            </div>

            <!-- Class Numbers -->
            <div class="col-12 col-md-6 col-lg-4">
              <label class="form-label" for="f-class">Class Numbers</label>
              <select id="f-class" name="class" class="form-select">
                <option value="">All classes</option>
                @foreach (var c in classNumbers)
                {
                       <option value="@c" selected="@(cls == c.ToString())">
                            @c
                       </option>
                }
              </select>
          </div>

            <!-- Registration Office (bonus) -->
            <div class="col-12 col-md-6 col-lg-4">
              <label class="form-label" for="f-office">Registration Office</label>
              <select id="f-office" name="office" class="form-select">
                <option value="">Any</option>
                @foreach (var o in officeItems)
                {
                        <option value="@o" selected="@(office == o.ToString())">@o</option>
                }
              </select>
            </div>

            <!-- Search Mode (bonus) -->
            <div class="col-12 col-md-6 col-lg-4">
              <label class="form-label" for="f-mode">Search Mode</label>
              <select id="f-mode" name="mode" class="form-select">
                <option value="">Default</option>
                @foreach (var m in modeItems)
                {
                        <option value="@m" selected="@(mode == m)">@m</option>
                }
              </select>
            </div>

            <div class="col-12 col-lg-4 d-flex align-items-end">
              <button class="btn btn-outline-secondary me-2" type="reset">Clear</button>
              <button class="btn btn-primary" type="submit">Apply</button>
            </div>
          </div>
        </form>
      </div>
    </div>

  </div>
</section>
