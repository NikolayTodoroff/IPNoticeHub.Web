@using IPNoticeHub.Web.ViewModels.Trademarks
@using System.Globalization
@using static IPNoticeHub.Shared.Constants.DateTimeFormats.DefaultDateTimeFormat
@model TrademarkDetailsViewModel

@{
    ViewData["Title"] = "Trademark Details";
    Layout = "_Layout";

    // Set by the controller ONLY if local. Used for the Back button.
    var returnUrl = ViewBag.ReturnUrl as string;

    // Always come back to THIS page after POSTs.
    var selfUrl = (Context?.Request?.Path + Context?.Request?.QueryString)
                  ?? Url.Action("Details", "Trademarks", new { id = Model.PublicId })!;
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="d-flex align-items-center gap-2">
            <h2 class="mb-0">Trademark Details</h2>

            @* State badges *@
            @if (Model?.IsInCollection == true)
            {
                <span class="badge text-bg-success">In Collection</span>
            }
            @if (Model?.IsInWatchlist == true)
            {
                <span class="badge text-bg-info">In Watchlist</span>
            }
        </div>

        @* Back button *@
        @if (!string.IsNullOrWhiteSpace(returnUrl))
        {
            <a class="btn btn-outline-secondary" href="@returnUrl">Back</a>
        }
        else
        {
            <a class="btn btn-outline-secondary" asp-controller="Trademarks" asp-action="MyCollection">
                Back to Trademarks
            </a>
        }
    </div>

    @* -------- Details card -------- *@
    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Registration Number</dt>
                <dd class="col-sm-9">@(!string.IsNullOrWhiteSpace(Model?.RegistrationNumber) ? Model.RegistrationNumber : "—")</dd>

                <dt class="col-sm-3">Wordmark</dt>
                <dd class="col-sm-9">@(!string.IsNullOrWhiteSpace(Model?.Wordmark) ? Model.Wordmark : "—")</dd>

                <dt class="col-sm-3">Owner</dt>
                <dd class="col-sm-9">@(!string.IsNullOrWhiteSpace(Model?.Owner) ? Model.Owner : "—")</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@(!string.IsNullOrWhiteSpace(Model?.Status.ToString()) ? Model.Status : "—")</dd>

                <dt class="col-sm-3">Classes</dt>
                <dd class="col-sm-9">
                    @(Model?.Classes != null && Model.Classes.Any()
                                        ? string.Join(", ", Model.Classes)
                                        : "—")
                </dd>

                <dt class="col-sm-3">Filing Date</dt>
                <dd class="col-sm-9">@((Model?.FilingDate)?.ToString(DateTimeFormat, CultureInfo.InvariantCulture) ?? "—")</dd>

                <dt class="col-sm-3">Registration Date</dt>
                <dd class="col-sm-9">@((Model?.RegistrationDate)?.ToString(DateTimeFormat, CultureInfo.InvariantCulture) ?? "—")</dd>

                <dt class="col-sm-3">Source Office</dt>
                <dd class="col-sm-9">@(!string.IsNullOrWhiteSpace(Model?.Provider.ToString()) ? Model.Provider : "—")</dd>

                <dt class="col-sm-3">Goods/Services</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrWhiteSpace(Model?.GoodsAndServices))
                    {
                        <div style="white-space:pre-wrap">@Model!.GoodsAndServices</div>
                    }
                    else
                    {
                        @:—
                    }
                </dd>

                @if (!string.IsNullOrWhiteSpace(Model?.MarkImageUrl))
                {
                    <dt class="col-sm-3">Official Record</dt>
                    <dd class="col-sm-9">
                        <a href="@Model!.MarkImageUrl" target="_blank" rel="noopener">Open in registry</a>
                    </dd>
                }
            </dl>
        </div>
    </div>
    
    @* -------- Actions -------- *@
    <div class="mt-3 d-flex gap-2">

        @if (Model?.IsAuthenticated == true)
        {
            @if (Model?.IsInCollection != true)
            {
                <form method="post"
                      asp-controller="Trademarks"
                      asp-action="Add"
                      class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="trademarkId" value="@Model!.Id" />
                    <input type="hidden" name="returnUrl" value="@selfUrl" />
                    <button type="submit" class="btn btn-outline-secondary">Save</button>
                </form>
            }

            @if (Model?.IsInCollection == true && Model?.IsAuthenticated == true)
            {
                <a asp-controller="TrademarkCad"
                   asp-action="CeaseDesist"
                   asp-route-publicId="@Model.PublicId"
                   class="btn btn-primary">
                    Cease &amp; Desist
                </a>
            }

            @if (Model?.IsInWatchlist != true)
            {
                <form method="post"
                      asp-controller="Watchlist"
                      asp-action="Add"
                      class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="trademarkId" value="@Model!.Id" />
                    <input type="hidden" name="returnUrl" value="@selfUrl" />
                    <button type="submit" class="btn btn-outline-primary">Add To Watchlist</button>
                </form>
            }
        } 
    </div>
</div>
