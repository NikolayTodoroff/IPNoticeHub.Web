@using IPNoticeHub.Services.Trademarks.DTOs;
@model TrademarkDetailsDTO
@{
    ViewData["Title"] = "Trademark Details";
    Layout = "_Layout";
    var returnUrl = ViewBag.ReturnUrl as string;
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Trademark Details</h2>
        @if (!string.IsNullOrWhiteSpace(returnUrl))
        {
            <a class="btn btn-outline-secondary" href="@returnUrl">Back to results</a>
        }
        else
        {
            <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Index">Back</a>
        }
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Registration No.</dt>
                <dd class="col-sm-9">@Model.RegistrationNumber</dd>

                <dt class="col-sm-3">Wordmark</dt>
                <dd class="col-sm-9">@Model.Wordmark</dd>

                <dt class="col-sm-3">Owner</dt>
                <dd class="col-sm-9">@Model.Owner</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@Model.Status</dd>

                <dt class="col-sm-3">Classes</dt>
                <dd class="col-sm-9">
                    @if (Model.Classes != null && Model.Classes.Any())
                    {
                        <span>@string.Join(", ", Model.Classes)</span>
                    }
                    else
                    {
                        <span class="text-muted">—</span>
                    }
                </dd>

                <dt class="col-sm-3">Filing Date</dt>
                <dd class="col-sm-9">@Model.FilingDate?.ToString("yyyy-MM-dd")</dd>

                <dt class="col-sm-3">Registration Date</dt>
                <dd class="col-sm-9">@Model.RegistrationDate?.ToString("yyyy-MM-dd")</dd>

                <dt class="col-sm-3">Source Office</dt>
                <dd class="col-sm-9">@Model.Provider</dd>

                <dt class="col-sm-3">Goods/Services</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrWhiteSpace(Model.GoodsAndServices))
                    {
                        <div style="white-space:pre-wrap">@Model.GoodsAndServices</div>
                    }
                    else
                    {
                        <span class="text-muted">—</span>
                    }
                </dd>

                @* Optional external link *@
                @if (!string.IsNullOrWhiteSpace(Model.MarkImageUrl))
                {
                    <dt class="col-sm-3">Official Record</dt>
                    <dd class="col-sm-9">
                        <a href="@Model.MarkImageUrl" target="_blank" rel="noopener">Open in registry</a>
                    </dd>
                }
            </dl>
        </div>
    </div>

    <div class="mt-3 d-flex gap-2">
        <form method="post" asp-controller="Trademarks" asp-action="Save" class="d-inline">
            <input type="hidden" name="id" value="@Model.PublicId" />
            <button type="submit" class="btn btn-outline-secondary" disabled>Save (coming soon)</button>
        </form>

        <form method="post" asp-controller="Watchlist" asp-action="Add" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="trademarkId" value="@Model.PublicId" />
            <button type="submit" class="btn btn-outline-secondary">Add to Watchlist</button>
        </form>

    </div>

</div>
