@model IPNoticeHub.Web.Models.PdfGeneration.CeaseDesistViewModel
@{
    ViewData["Title"] = "Edit Cease & Desist";
    Layout = "_Layout";
}
<style>
    /* A4 frame + sheet */
    .a4-frame {
        display: flex;
        justify-content: center;
        padding: 24px;
    }

    .a4-paper {
        width: 210mm;
        height: 297mm;
        background: #fff;
        color: #222;
        box-shadow: 0 12px 32px rgba(16,24,40,.12);
        border-radius: 4px;
        padding: 20mm;
        overflow: auto;
        line-height: 1.6;
        font-family: "Times New Roman", Times, serif;
        font-size: 12pt;
    }
        /* make headings/links slightly bolder */
        .a4-paper b, .a4-paper strong {
            font-weight: 700;
        }
</style>

<div class="container py-4">
    <h2>Edit Cease &amp; Desist</h2>

    <form asp-action="CeaseDesist" method="post">
        <input type="hidden" asp-for="PublicId" />
        <input type="hidden" asp-for="SenderName" />
        <input type="hidden" asp-for="SenderAddress" />
        <input type="hidden" asp-for="RecipientName" />
        <input type="hidden" asp-for="RecipientAddress" />
        <input type="hidden" asp-for="WorkTitle" />
        <input type="hidden" asp-for="RegistrationNumber" />
        <input type="hidden" asp-for="AdditionalFacts" />

        <div class="a4-frame">
            <textarea asp-for="BodyTemplate" class="a4-paper"></textarea>
        </div>

        <div class="mt-3 d-flex gap-2 justify-content-center">
            <button class="btn btn-primary">Generate PDF</button>

            <button type="submit"
                    class="btn btn-outline-secondary"
                    formnovalidate
                    formmethod="post"
                    formaction="@Url.Action("CeaseDesistPreview")">
                Cancel
            </button>
        </div>
    </form>
</div>
