@model IPNoticeHub.Web.Models.PdfGeneration.CeaseDesistViewModel
@{
    ViewData["Title"] = "Edit Cease & Desist";
    Layout = "_Layout";
    var resetUrl = Url.Action("CeaseDesistPreview", new { publicId = Model.PublicId, reset = 1 }); // optional
}
<style>
    .a4-frame {
        display: flex;
        justify-content: center;
        padding: 24px;
    }

    .a4-paper {
        width: 210mm;
        height: 297mm;
        background: #fff;
        color: #222;
        box-shadow: 0 12px 32px rgba(16,24,40,.12);
        border-radius: 4px;
        padding: 20mm;
        overflow: auto;
        line-height: 1.6;
        font-family: "Times New Roman", Times, serif;
        font-size: 12pt;
        white-space: pre-wrap;
    }

        .a4-paper b, .a4-paper strong {
            font-weight: 700;
        }
</style>

<div class="container py-4">
    <h2>Edit Cease &amp; Desist</h2>

    <form asp-action="CeaseDesist" method="post" id="cdTrademarkForm">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="PublicId" />
        <input type="hidden" asp-for="SenderName" />
        <input type="hidden" asp-for="SenderAddress" />
        <input type="hidden" asp-for="RecipientName" />
        <input type="hidden" asp-for="RecipientAddress" />
        <input type="hidden" asp-for="WorkTitle" />
        <input type="hidden" asp-for="RegistrationNumber" />
        <input type="hidden" asp-for="AdditionalFacts" />

        <!-- Original text (last saved) for Cancel -->
        <textarea id="OriginalBodyTemplate" class="d-none">@Model.BodyTemplate</textarea>

        <div class="a4-frame">
            <textarea asp-for="BodyTemplate" class="a4-paper" id="BodyTemplate"></textarea>
        </div>

        <div class="mt-3 d-flex flex-wrap gap-2 justify-content-center">
            <!-- Generate PDF (default action) -->
            <button type="submit" class="btn btn-primary" id="btnGenerate">Generate PDF</button>

            <!-- Save → Preview with current edits -->
            <button type="submit"
                    class="btn btn-success"
                    formnovalidate
                    formmethod="post"
                    formaction="@Url.Action("CeaseDesistPreview")"
                    id="btnSave">
                Save
            </button>

            <!-- Cancel → Preview with original (discard current edits) -->
            <button type="submit"
                    class="btn btn-outline-secondary"
                    formnovalidate
                    formmethod="post"
                    formaction="@Url.Action("CeaseDesistPreview")"
                    id="btnCancel">
                Cancel
            </button>

            <!-- Optional Reset (GET) -->
            <a href="@resetUrl" class="btn btn-outline-danger">Reset</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        (function () {
          const form     = document.getElementById('cdTrademarkForm');
          const textarea = document.getElementById('BodyTemplate');
          const original = document.getElementById('OriginalBodyTemplate');

          // Save/Generate: do nothing special (current textarea value will be posted)

          // Cancel: restore original text just before submit
          document.getElementById('btnCancel').addEventListener('click', function () {
            textarea.value = original.value;
          });
        })();
    </script>
}
