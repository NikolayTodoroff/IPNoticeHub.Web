@model IPNoticeHub.Web.Models.PdfGeneration.DMCAViewModel
@{
    ViewData["Title"] = "Generate DMCA Notice";
    Layout = "_Layout";
}

<div class="container py-4">
    <h2>Generate DMCA Notice</h2>

    <!-- GET form: loads selected template -->
    <form asp-action="Dmca" method="get" class="mb-3">
        <input type="hidden" asp-for="PublicId" />
        <div class="row g-2 align-items-end">
            <div class="col-md-6">
                <label class="form-label">Template</label>
                <select asp-for="TemplateKey"
                        asp-items="Model.TemplateOptions"
                        class="form-select"></select>
            </div>
            <div class="col-auto">
                <button class="btn btn-outline-secondary">Load Template</button>
            </div>
        </div>
    </form>

    <!-- POST form: generates the PDF -->
    <form asp-action="Dmca" method="post">
        <input type="hidden" asp-for="PublicId" />
        <partial name="~/Views/Shared/_PdfFormFields.cshtml" model="Model" />
    </form>
</div>
