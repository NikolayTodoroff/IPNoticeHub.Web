@model IPNoticeHub.Web.Models.PdfGeneration.DMCAViewModel
@{
    ViewData["Title"] = "Edit DMCA Notice";
    Layout = "_Layout";
}
<style>
    .a4-frame {
        display: flex;
        justify-content: center;
        padding: 24px;
    }

    .a4-paper {
        width: 210mm;
        height: 297mm;
        background: #fff;
        color: #222;
        box-shadow: 0 12px 32px rgba(16,24,40,.12);
        border-radius: 4px;
        padding: 20mm;
        overflow: auto;
        line-height: 1.6;
        font-family: "Times New Roman", Times, serif;
        font-size: 12pt;
        white-space: pre-wrap;
    }

        .a4-paper b,
        .a4-paper strong {
            font-weight: 700;
        }

    textarea#BodyTemplateHidden {
        resize: none;
    }

    html, body {
        overflow-x: hidden;
    }

    @@page {
        size: A4;
        margin: 20mm;
    }

    @@media print {
        .a4-frame {
            padding: 0;
        }

        .a4-paper {
            box-shadow: none;
            height: auto;
            overflow: visible;
        }
    }
</style>

<div class="container py-4">
    <h2 class="mb-3 text-center">Edit DMCA Notice</h2>

    <div class="a4-frame">
        <div id="a4Editor" class="a4-paper" contenteditable="true">
            @Model.BodyTemplate
        </div>
    </div>

    <textarea id="OriginalBodyTemplate" class="d-none">@Model.BodyTemplate</textarea>

    <div class="mt-3 d-flex flex-wrap gap-2 justify-content-center">

        <form asp-action="Dmca" method="post" id="dmcaGenerateForm" class="d-inline">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="PublicId" />
            <input type="hidden" asp-for="SenderName" />
            <input type="hidden" asp-for="SenderEmail" />
            <input type="hidden" asp-for="SenderAddress" />
            <input type="hidden" asp-for="RecipientName" />
            <input type="hidden" asp-for="RecipientEmail" />
            <input type="hidden" asp-for="RecipientAddress" />
            <input type="hidden" asp-for="WorkTitle" />
            <input type="hidden" asp-for="RegistrationNumber" />
            <input type="hidden" asp-for="InfringingUrl" />
            <input type="hidden" asp-for="YearOfCreation" />
            <input type="hidden" asp-for="DateOfPublication" />
            <input type="hidden" asp-for="NationOfFirstPublication" />
            <input type="hidden" asp-for="GoodFaithStatement" />

            <textarea asp-for="BodyTemplate" id="BodyTemplatePdf" class="d-none"></textarea>

            <button type="submit" class="btn btn-primary" id="btnGenerate">
                Generate PDF
            </button>
        </form>

        <form asp-action="DmcaEdit" method="post" id="dmcaEditForm" class="d-inline">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="PublicId" />
            <input type="hidden" asp-for="SenderName" />
            <input type="hidden" asp-for="SenderEmail" />
            <input type="hidden" asp-for="SenderAddress" />
            <input type="hidden" asp-for="RecipientName" />
            <input type="hidden" asp-for="RecipientEmail" />
            <input type="hidden" asp-for="RecipientAddress" />
            <input type="hidden" asp-for="WorkTitle" />
            <input type="hidden" asp-for="RegistrationNumber" />
            <input type="hidden" asp-for="InfringingUrl" />
            <input type="hidden" asp-for="YearOfCreation" />
            <input type="hidden" asp-for="DateOfPublication" />
            <input type="hidden" asp-for="NationOfFirstPublication" />
            <input type="hidden" asp-for="GoodFaithStatement" />

            <textarea asp-for="BodyTemplate" id="BodyTemplateEdit" class="d-none"></textarea>

            <button type="button"
                    class="btn btn-outline-danger"
                    id="btnReset">
                Reset
            </button>

            <button type="submit"
                    name="command"
                    value="save"
                    class="btn btn-success">
                Save
            </button>

            <button type="submit"
                    name="command"
                    value="done"
                    class="btn btn-outline-secondary">
                Done
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const editor   = document.getElementById('a4Editor');
            const original = document.getElementById('OriginalBodyTemplate');
            const pdfBody  = document.getElementById('BodyTemplatePdf');
            const editBody = document.getElementById('BodyTemplateEdit');

            function plainText(el) {
                return el.innerText.replace(/\r\n/g, '\n');
            }
            document.getElementById('btnReset')
                .addEventListener('click', function () {
                    editor.innerText = original.value;
                });

            document.getElementById('dmcaGenerateForm')
                .addEventListener('submit', function () {
                    pdfBody.value = plainText(editor);
                });

            document.getElementById('dmcaEditForm')
                .addEventListener('submit', function () {
                    editBody.value = plainText(editor);
                });
        })();
    </script>
}
