@model IPNoticeHub.Web.Models.PdfGeneration.DMCAViewModel
@{
    ViewData["Title"] = "Edit DMCA Notice";
    Layout = "_Layout";
    var resetUrl = Url.Action("DmcaPreview", new { publicId = Model.PublicId, reset = 1 }); // optional
}
<style>
    .a4-frame {
        display: flex;
        justify-content: center;
        padding: 24px;
    }

    .a4-paper {
        width: 210mm;
        height: 297mm;
        background: #fff;
        color: #222;
        box-shadow: 0 12px 32px rgba(16,24,40,.12);
        border-radius: 4px;
        padding: 20mm;
        overflow: auto;
        line-height: 1.6;
        font-family: "Times New Roman", Times, serif;
        font-size: 12pt;
        white-space: pre-wrap;
    }

        .a4-paper b, .a4-paper strong {
            font-weight: 700;
        }

    textarea#BodyTemplateHidden {
        resize: none;
    }

    html, body {
        overflow-x: hidden;
    }

    @@page {
        size: A4;
        margin: 20mm;
    }

    @@media print {
        .a4-frame {
            padding: 0;
        }

        .a4-paper {
            box-shadow: none;
            height: auto;
            overflow: visible;
        }
    }
</style>

<div class="container py-4">
    <h2 class="mb-3 text-center">Edit DMCA Notice</h2>

    <form asp-action="DmcaEdit" method="post" id="dmcaEditForm">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="PublicId" />
        <input type="hidden" asp-for="SenderName" />
        <input type="hidden" asp-for="SenderEmail" />
        <input type="hidden" asp-for="SenderAddress" />
        <input type="hidden" asp-for="RecipientName" />
        <input type="hidden" asp-for="RecipientEmail" />
        <input type="hidden" asp-for="RecipientAddress" />
        <input type="hidden" asp-for="WorkTitle" />
        <input type="hidden" asp-for="RegistrationNumber" />
        <input type="hidden" asp-for="InfringingUrl" />
        <input type="hidden" asp-for="YearOfCreation" />
        <input type="hidden" asp-for="DateOfPublication" />
        <input type="hidden" asp-for="NationOfFirstPublication" />
        <input type="hidden" asp-for="GoodFaithStatement" />
        <input type="hidden" asp-for="GoodFaithStatement" />

        <!-- MVC binds from this hidden field -->
        <textarea asp-for="BodyTemplate" id="BodyTemplateHidden" class="d-none"></textarea>
        <!-- Keep original (last saved) to support Cancel -->
        <textarea id="OriginalBodyTemplate" class="d-none">@Model.BodyTemplate</textarea>

        <div class="a4-frame">
            <div id="a4Editor" class="a4-paper" contenteditable="true">
                @Model.BodyTemplate
            </div>
        </div>

        <div class="mt-3 d-flex flex-wrap gap-2">
            <button type="submit"
                    class="btn btn-primary"
                    formmethod="post"
                    formaction="@Url.Action("Dmca", new { publicId = Model.PublicId })"
                    id="btnGenerate">
                Generate PDF
            </button>

            <!-- Save → Preview with current edits -->
            <button type="submit"
                    class="btn btn-success"
                    formnovalidate
                    formmethod="post"
                    formaction="@Url.Action("DmcaPreview")"
                    id="btnSave">
                Save
            </button>

            <!-- Cancel → Preview with original (discard current edits) -->
            <button type="submit"
                    class="btn btn-outline-secondary"
                    formnovalidate
                    formmethod="post"
                    formaction="@Url.Action("DmcaPreview")"
                    id="btnCancel">
                Cancel
            </button>

            <!-- Optional full baseline reset (GET) -->
            <a href="@resetUrl" class="btn btn-outline-danger">Reset</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        (function () {
          const form    = document.getElementById('dmcaEditForm');
          const editor  = document.getElementById('a4Editor');
          const hidden  = document.getElementById('BodyTemplateHidden');
          const original= document.getElementById('OriginalBodyTemplate');

          function plainText(el){ return el.innerText.replace(/\r\n/g, '\n'); }

          // Default: submit current editor value
          function syncCurrent(){ hidden.value = plainText(editor); }

          // On load
          syncCurrent();

          // Always resync right before submit (for Generate/Save by default)
          form.addEventListener('submit', function () {
            syncCurrent();
          });

          // Cancel: overwrite hidden with original right before submit
          document.getElementById('btnCancel').addEventListener('click', function () {
            hidden.value = original.value;
          });

          // Keep hidden updated as user types (not required but nice)
          editor.addEventListener('input', syncCurrent);
        })();
    </script>
}
