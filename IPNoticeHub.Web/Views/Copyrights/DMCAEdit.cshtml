@model IPNoticeHub.Web.Models.PdfGeneration.DMCAViewModel
@{
    ViewData["Title"] = "Edit DMCA Notice";
    Layout = "_Layout";
}

<div class="container py-4">
    <h2>Edit DMCA Notice</h2>

    <form asp-action="Dmca" method="post">
        <input type="hidden" asp-for="PublicId" />
        <partial name="~/Views/Shared/_PdfFormFields.cshtml" model="Model" />

        <div class="mt-3 d-flex gap-2">
            <button class="btn btn-primary">Generate PDF</button>
            <button type="button" class="btn btn-outline-secondary" onclick="history.back()">Back</button>
        </div>
    </form>
</div>
