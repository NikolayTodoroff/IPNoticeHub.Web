@model IPNoticeHub.Web.Models.PdfGeneration.DMCAViewModel
@{
    ViewData["Title"] = "Edit DMCA Notice";
    Layout = "_Layout";
}

<style>
    :root {
        --a4-w: 210; /* A4 width mm */
        --a4-h: 297; /* A4 height mm */
    }

    body {
        background: #f5f7fb;
    }

    .a4-wrap {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding: 1.5rem 0;
    }

    /* Fit one A4 page by viewport height, keep true A4 ratio */
    .a4-sheet {
        --usable-h: calc(100vh - 140px); /* leave room for navbar etc. */
        height: var(--usable-h);
        width: calc(var(--usable-h) * (var(--a4-w) / var(--a4-h)));
        background: #fff;
        box-shadow: 0 10px 30px rgba(0,0,0,.10);
        border-radius: 6px;
        /* Add a faint outline so it’s visible even on white pages */
        outline: 1px solid rgba(0,0,0,.06);
        padding: clamp(16px, 3vh, 28px); /* proportional margins */
        display: flex;
    }

    .a4-editor {
        flex: 1 1 auto;
        border: none;
        outline: none;
        resize: none; /* one page only; no inner scroller */
        overflow: hidden; /* anything beyond one page is hidden */
        background: transparent;
        width: 100%;
        height: 100%;
        font-family: "Georgia", "Times New Roman", serif;
        font-size: 16px;
        line-height: 1.7;
        color: #111;
        white-space: pre-wrap;
    }

    @@media (max-width: 1100px) {
        .a4-sheet

    {
        height: calc(100vh - 120px);
    }

    }

    .btn-bar {
        display: flex;
        justify-content: center;
        gap: 1rem;
        margin: 1.25rem 0 2rem;
    }
</style>

<div class="container-fluid">
    <h2 class="mt-3 mb-4 text-center">Edit DMCA Notice</h2>

    <form asp-action="Dmca" method="post">
        <input type="hidden" asp-for="PublicId" />

        <!-- Keep required meta fields hidden so Generate can bind; rehydrate server-owned fields in controller -->
        <input type="hidden" asp-for="SenderName" />
        <input type="hidden" asp-for="SenderEmail" />
        <input type="hidden" asp-for="SenderAddress" />
        <input type="hidden" asp-for="RecipientName" />
        <input type="hidden" asp-for="RecipientEmail" />
        <input type="hidden" asp-for="RecipientAddress" />
        <input type="hidden" asp-for="WorkTitle" />
        <input type="hidden" asp-for="RegistrationNumber" />
        <input type="hidden" asp-for="YearOfCreation" />
        <input type="hidden" asp-for="DateOfPublication" />
        <input type="hidden" asp-for="NationOfFirstPublication" />
        <input type="hidden" asp-for="GoodFaithStatement" />

        <div class="a4-wrap">
            <div class="a4-sheet">
                <textarea asp-for="BodyTemplate" class="a4-editor"></textarea>
            </div>
        </div>

        <div class="btn-bar">
            <button class="btn btn-primary px-4">Generate PDF</button>
            <a asp-action="DmcaPreview" asp-route-publicId="@Model.PublicId"
               class="btn btn-outline-secondary px-4">Cancel</a>
        </div>
    </form>
</div>
