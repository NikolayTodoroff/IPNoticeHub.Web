@model IPNoticeHub.Web.Models.PdfGeneration.DMCAViewModel
@{
    ViewData["Title"] = "Edit DMCA Notice";
    Layout = "_Layout";
}

<style>

/* Frame that centers the paper on the page */
.a4-frame {
  display: flex;
  justify-content: center;
  padding: 24px;
}

/* The document – strictly A4, with internal scroll once full */
.a4-paper {
  width: 210mm;
  height: 297mm;
  background: #fff;
  color: #222;
  box-shadow: 0 12px 32px rgba(16,24,40,.12);
  border-radius: 4px;
  padding: 20mm;                 
  overflow: auto;                
  line-height: 1.6;
  font-family: "Times New Roman", Times, serif;
  font-size: 12pt;
  white-space: pre-wrap;
}

/* Emphasis inside the document */
.a4-paper b, .a4-paper strong { font-weight: 700; }

/* Prevent user resize for the hidden <textarea> we post */
textarea#BodyTemplateHidden { resize: none; }

/* Optional: keep the viewport from horizontal scrolling */
html, body { overflow-x: hidden; }

/* Print-friendly (handy for quick browser prints while testing) */
@@page { size: A4; margin: 20mm; }
@@media print {
  .a4-frame { padding: 0; }
  .a4-paper { box-shadow: none; height: auto; overflow: visible; }
}
</style>

<div class="container py-4">
    <h2 class="mb-3 text-center">Edit DMCA Notice</h2>

    <form asp-action="Dmca" method="post" id="dmcaEditForm">
        <input type="hidden" asp-for="PublicId" />
        <!-- MVC binds from this hidden field; we keep it in sync with the editor on submit -->
        <textarea asp-for="BodyTemplate" id="BodyTemplateHidden" class="d-none"></textarea>

        <div class="a4-frame">
            <!-- Contenteditable A4 page -->
            <div id="a4Editor" class="a4-paper" contenteditable="true">
                @Model.BodyTemplate
            </div>
        </div>

        <div class="mt-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Generate PDF</button>
            <a asp-action="DmcaPreview"
               asp-route-publicId="@Model.PublicId"
               class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
<script>
(function () {
  const form   = document.getElementById('dmcaEditForm');
  const editor = document.getElementById('a4Editor');
  const hidden = document.getElementById('BodyTemplateHidden');

  // Ensure hidden field mirrors the editor when submitting
  form.addEventListener('submit', function () {
    // Keep plain text with newlines (your PDF template expects text, not HTML)
    hidden.value = editor.innerText.replace(/\r\n/g, '\n');
  });

  // Initialize the hidden field on load (helps if user clicks Generate immediately)
  hidden.value = editor.innerText.replace(/\r\n/g, '\n');
})();
</script>
}
