@using System
@using IPNoticeHub.Shared.Support;
@using IPNoticeHub.Application.DTOs.CopyrightDTOs
@using static IPNoticeHub.Shared.Constants.DateTimeFormats.DefaultDateTimeFormat
@using System.Globalization
@model IPNoticeHub.Web.Models.Copyrights.CopyrightCollectionViewModel;

@{
    ViewData["Title"] = "My Copyrights";

    var hasRows = Model != null && Model.Results != null && Model.Results.Count > 0;

    var page = Model?.CurrentPage ?? 1;
    var pageSize = Math.Max(Model?.PageSize ?? 10, 1);
    var total = Model?.Total ?? 0;
    var totalPages = Math.Max(Model?.TotalPages ?? 1, 1);

    var sort = ViewBag.SortBy as string ?? string.Empty;

    var prevClass = page <= 1 ? "disabled" : null;
    var nextClass = page >= totalPages ? "disabled" : null;

    var currentUrl = Context.Request.Path + Context.Request.QueryString;
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">My Copyrights</h2>
        <a asp-action="Create" class="btn btn-primary">Add Copyright</a>
    </div>

    @if (hasRows)
    {
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th scope="col">Reg. No.</th>
                        <th scope="col">Type of Work</th>
                        <th scope="col">Title</th>
                        <th scope="col">Date of Publication</th>
                        <th scope="col" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model?.Results != null)
                    {
                        foreach (var item in Model.Results)
                        {
                            <tr>
                                <td>@item.RegistrationNumber</td>
                                <td>@item.TypeOfWork</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.PublicId">@item.Title</a>
                                </td>
                                <td>@(item.DateOfPublication?.ToString(DateTimeFormat, CultureInfo.InvariantCulture) ?? "—")</td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end align-items-stretch gap-2">

                                        <a asp-controller="CopyrightCad"
                                            asp-action="CeaseDesist"
                                           asp-route-publicId="@item.PublicId"
                                           class="btn btn-primary">
                                            Cease &amp; Desist
                                        </a>

                                        <a asp-controller="CopyrightDmca" 
                                           asp-action="Dmca"
                                           asp-route-publicId="@item.PublicId"
                                           class="btn btn-primary">
                                            DMCA Notice
                                        </a>

                                        <a class="btn btn-secondary btn-sm"
                                           asp-controller="Copyrights"
                                           asp-action="Details"
                                           asp-route-id="@item.PublicId"
                                           asp-route-returnUrl="@currentUrl">
                                            Details
                                        </a>
                                        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@item.PublicId">Edit</a>
                                        <form asp-action="Remove" asp-route-id="@item.PublicId" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="returnUrl" value="@Url.Action("MyCollection", "Copyrights")" />
                                            <button type="submit" class="btn btn-outline-danger"
                                                    onclick="return confirm('Remove this copyright from your collection?');">
                                                Remove
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @* --- Pager --- *@
@if (totalPages > 1)
{
    <nav aria-label="Pagination">
        <ul class="pagination justify-content-center">

            <li class="page-item @(page <= 1 ? "disabled" : "")">
                <a class="page-link"
                   asp-action="MyCollection"
                   asp-route-currentPage="@(page - 1)"
                   asp-route-resultsPerPage="@pageSize"
                   asp-route-sortBy="@sort">
                    &lt; Previous
                </a>
            </li>

                    <li class="page-item disabled">
                        <span class="page-link">
                            Page @Model!.CurrentPage of @Model.TotalPages
                        </span>
                    </li>

            <li class="page-item @(page >= totalPages ? "disabled" : "")">
                <a class="page-link"
                   asp-action="MyCollection"
                   asp-route-currentPage="@(page + 1)"
                   asp-route-resultsPerPage="@pageSize"
                   asp-route-sortBy="@sort">
                    Next &gt;
                </a>
            </li>

        </ul>
    </nav>
}

    }
    else
    {
        <div class="alert alert-info">No copyrights yet. Add your first one!</div>
    }
</div>
