@model IPNoticeHub.Web.Models.PdfGeneration.CeaseDesistViewModel
@{
    ViewData["Title"] = "Edit Cease & Desist";
    Layout = "_Layout";

    var resetUrl = Url.Action("CeaseDesistPreview", new { publicId = Model.PublicId, reset = 1 }); // optional Reset
}

<style>
    .a4-frame {
        display: flex;
        justify-content: center;
        padding: 24px;
        background: #f6f6f6;
    }

    .a4-paper {
        width: 210mm;
        height: 297mm;
        background: #fff;
        color: #222;
        box-shadow: 0 12px 32px rgba(16,24,40,.12);
        border-radius: 6px;
        border: 1px solid rgba(0,0,0,.06);
        padding: 20mm;
        overflow: auto;
        line-height: 1.6;
        font-family: "Times New Roman", Times, serif;
        font-size: 12pt;
        white-space: pre-wrap;
    }

        .a4-paper:focus {
            outline: none;
            box-shadow: 0 0 0 3px rgba(59,130,246,.25), 0 12px 32px rgba(16,24,40,.12);
        }
</style>

<div class="container py-4">
    <h2>Edit Cease &amp; Desist</h2>

    <form asp-action="CeaseDesistEdit" method="post" id="cdEditForm">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="PublicId" />
        <input type="hidden" asp-for="SenderName" />
        <input type="hidden" asp-for="SenderAddress" />
        <input type="hidden" asp-for="SenderEmail" />
        <input type="hidden" asp-for="RecipientName" />
        <input type="hidden" asp-for="RecipientAddress" />
        <input type="hidden" asp-for="RecipientEmail" />
        <input type="hidden" asp-for="InfringingUrl" />
        <input type="hidden" asp-for="WorkTitle" />
        <input type="hidden" asp-for="RegistrationNumber" />
        <input type="hidden" asp-for="AdditionalFacts" />

        <input type="hidden" id="OriginalBodyTemplate" value="@Model.BodyTemplate" />

        <div class="a4-frame">
            <textarea asp-for="BodyTemplate" id="BodyTemplate" class="a4-paper" spellcheck="false"></textarea>
        </div>

        <div class="mt-3 d-flex flex-wrap gap-2 justify-content-center">

            <button type="submit" class="btn btn-primary">Generate PDF</button>

            <button type="submit"
                    class="btn btn-success"
                    formnovalidate
                    formmethod="post"
                    formaction="@Url.Action("CeaseDesistPreview")"
                    id="btnSave">
                Save
            </button>

            <a class="btn btn-outline-danger" href="@resetUrl">Reset</a>

            <button type="submit"
                    class="btn btn-outline-secondary"
                    formnovalidate
                    formmethod="post"
                    formaction="@Url.Action("CeaseDesistPreview")"
                    id="btnCancel">
                Back
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        (function () {
          const form = document.getElementById('cdEditForm');
          const textarea = document.getElementById('BodyTemplate');
          const original = document.getElementById('OriginalBodyTemplate');

          // Save does nothing special — it posts current textarea value

          // Cancel: before submit, swap the textarea value back to the original
          document.getElementById('btnCancel').addEventListener('click', function () {
            textarea.value = original.value; // discard current edits
          });
        })();
    </script>
}
