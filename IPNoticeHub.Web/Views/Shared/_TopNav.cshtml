@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom">
    <div class="container">
        <!-- Homepage - Trademark Search -->
        <a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index">IPNoticeHub</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto">

                <!-- Admin Dashboard -->
                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item">
                        <a class="nav-link fw-bold text-danger" asp-area="Admin" asp-controller="Admin" asp-action="Index">
                            Admin Dashboard
                        </a>
                    </li>
                }

                <!-- Trademark Search (Homepage) -->
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">Trademark Search</a>
                </li>

                <!-- Trademark/Copyright Collections -->
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Trademarks" asp-action="MyCollection">My Trademarks</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Copyrights" asp-action="MyCollection">My Copyrights</a>
                </li>

                <!-- Watchlist/Documents -->
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Watchlist" asp-action="Index">Watchlist</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Documents" asp-action="Index">Document Library</a>
                </li>
            </ul>

            <ul class="navbar-nav ms-auto">
                <partial name="_LoginPartial" />
            </ul>
        </div>
    </div>
</nav>
