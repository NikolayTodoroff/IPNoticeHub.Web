@{
    ViewData["Title"] = "Page not found";
    Layout = "_Layout";
}

<main class="py-4">
    <div class="container">
        <h1 class="display-5 mb-3">Oops, page not found (404)</h1>
        <p class="lead">
            The page you were looking for doesn’t exist, was moved, or never made it out of staging.
        </p>

        <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">
            ← Back to home
        </a>
    </div>
</main>
