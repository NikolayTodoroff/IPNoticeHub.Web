@using IPNoticeHub.Web.Models.Trademarks;
@model TrademarkSearchResultsViewModel;

<section class="py-4">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h2 class="h5 mb-0">Results</h2>
            @if (Model.Total > 0)
            {
                <span class="text-muted small">@Model.Total result(s)</span>
            }
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Reg. No.</th>
                                <th>Mark</th>
                                <th>Owner</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Results == null || !Model.Results.Any())
                            {
                                <tr class="text-muted">
                                    <td colspan="5" class="text-center py-5">No results yet. Try a search above.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var r in Model.Results)
                                {
                                    <tr>
                                        <td>@r.RegistrationNumber</td>
                                        <td>@r.Mark</td>
                                        <td>@r.Owner</td>
                                        <td>@r.Status</td>
                                        <td class="text-end">
                                            <a class="btn btn-sm btn-outline-primary" href="#">Details</a>
                                            <a class="btn btn-sm btn-outline-secondary ms-2" href="#">Save</a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>
