@using System.Globalization
@using IPNoticeHub.Web.Models.TrademarkSearch
@using IPNoticeHub.Web.Models.Trademarks
@using static IPNoticeHub.Common.ValidationConstants.FormattingConstants;
@model TrademarkSearchResultsViewModel

@{
    // Canonical return target for this page (path + query string)
    var currentUrl = (Context?.Request?.Path + Context?.Request?.QueryString) ?? "/";
}

<section class="py-4">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h2 class="h5 mb-0">Results</h2>
            @if (Model.Total > 0)
            {
                <span class="text-muted small">@Model.Total result(s)</span>
            }
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Reg.No.</th>
                                <th>Wordmark</th>
                                <th>Owner</th>
                                <th>Status</th>
                                <th>Registration Date</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Results == null || !Model.Results.Any())
                            {
                                <tr class="text-muted">
                                    <td colspan="5" class="text-center py-5">No trademarks matched your search.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var result in Model.Results)
                                {
                                    <tr>
                                        <td>@result.RegistrationNumber</td>
                                        <td>@result.Wordmark</td>
                                        <td>@result.Owner</td>
                                        <td>@result.Status</td>
                                        <td>@(result.RegistrationDate.HasValue ? 
                                            result.RegistrationDate.Value.ToString(DateTimeFormat, CultureInfo.InvariantCulture) : "")</td>
                                        <td class="text-end">
                                            <a class="btn btn-outline-primary btn-sm"
                                               asp-controller="Trademarks"
                                               asp-action="Details"
                                               asp-route-id="@result.PublicId"
                                               asp-route-returnUrl="@currentUrl">
                                                Details
                                            </a>

                                            <form method="post"
                                                  asp-controller="Trademarks"
                                                  asp-action="Add"
                                                  class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="trademarkId" value="@result.Id" />
                                                <input type="hidden" name="returnUrl" value="@currentUrl" />
                                                <button type="submit" class="btn btn-sm btn-outline-secondary ms-2">Save</button>
                                            </form>

                                            <form method="post"
                                                  asp-controller="Watchlist"
                                                  asp-action="Add"
                                                  class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="trademarkId" value="@result.Id" />
                                                <input type="hidden" name="returnUrl" value="@currentUrl" />
                                                <button type="submit" class="btn btn-sm btn-outline-secondary ms-2">Add To Watchlist</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @* --- Pager --- *@
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Search results pages" class="mt-3">
                <ul class="pagination justify-content-center">

                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link"
                           asp-controller="Home"
                           asp-action="Results"
                           asp-route-trademark="@Model.Query"
                           asp-route-classNumber="@Model.Class"
                           asp-route-status="@Model.Status"
                           asp-route-searchByItem="@Model.SearchBy"
                           asp-route-office="@Model.Office"
                           asp-route-mode="@Model.Mode"
                           asp-route-currentPage="@(Model.CurrentPage - 1)"
                           asp-route-pageSize="@Model.PageSize">
                            ‹ Previous
                        </a>
                    </li>

                    <li class="page-item disabled">
                        <span class="page-link">
                            Page @Model.CurrentPage of @Model.TotalPages
                        </span>
                    </li>

                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        <a class="page-link"
                           asp-controller="Home"
                           asp-action="Results"
                           asp-route-trademark="@Model.Query"
                           asp-route-classNumber="@Model.Class"
                           asp-route-status="@Model.Status"
                           asp-route-searchByItem="@Model.SearchBy"
                           asp-route-office="@Model.Office"
                           asp-route-mode="@Model.Mode"
                           asp-route-currentPage="@(Model.CurrentPage + 1)"
                           asp-route-pageSize="@Model.PageSize">
                            Next ›
                        </a>
                    </li>

                </ul>
            </nav>
        }
    </div>
</section>
