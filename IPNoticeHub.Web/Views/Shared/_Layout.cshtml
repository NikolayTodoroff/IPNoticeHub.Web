@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - IPNoticeHub.Web</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/IPNoticeHub.Web.styles.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        @await Html.PartialAsync("_TopNav")
    </header>

    <main class="flex-shrink-0">
        <div class="container py-4">
            <partial name="_Alerts" />
            @RenderBody()
        </div>
    </main>

    <footer class="border-top mt-auto py-3 bg-light">
        @await Html.PartialAsync("_Footer")
    </footer>

    <!-- Bootstrap JavaScript Bundle (includes Popper.js for tooltips and popovers) -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- SB UI Kit Pro JS -->
    <script src="~/js/scripts.js" asp-append-version="true"></script>

    <!-- jQuery library required for MVC unobtrusive validation -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <!-- Custom JavaScript for application-specific functionality -->
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- JavaScript specific to the application -->
    @RenderSection("Scripts", required: false)

    <!-- Universal Back button -->
    <script>
        document.addEventListener('click', function (e) 
        {
          const btn = e.target.closest('#btnBack');
          if (!btn) return;

          if (document.referrer) window.history.back();
          
          else window.location.href = '@Url.Action("Index", "Home")';
        });
    </script>
</body>
</html>
