@model IPNoticeHub.Web.Models.PdfGeneration.DmcaViewModel
@{
    ViewData["Title"] = "Generate DMCA Notice";
    Layout = "_Layout";
}

<div class="container py-4">
    <h2>Generate DMCA Notice</h2>

    <form asp-action="DmcaPreview" method="post">
        <input type="hidden" asp-for="PublicId" />
        <partial name="~/Views/Shared/_PdfFormFields.Basic.cshtml" model="Model" />

        <div class="mt-3 d-flex gap-2">
            <button class="btn btn-primary">Preview</button>
            <partial name="_BackButton" />
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
