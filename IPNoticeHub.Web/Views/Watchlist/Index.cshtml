@using IPNoticeHub.Application.DTOs.WatchlistDTOs
@using IPNoticeHub.Web.Models.Watchlist
@using System.Globalization
@using static IPNoticeHub.Shared.Constants.DateTimeFormats.DefaultDateTimeFormat
@model WatchlistIndexViewModel

@{
    ViewData["Title"] = "Watchlist";
    var currentUrl = (Context?.Request?.Path + Context?.Request?.QueryString) ?? Url.Action("Index", "Watchlist");
}

<h2 class="mb-3">Watchlist</h2>

@if (TempData["ErrorMessage"] is string e && !string.IsNullOrWhiteSpace(e))
{
    <div class="alert alert-danger" role="alert">@e</div>
}

@if (Model is null || !Model.Items.Any())
{
    <div class="alert alert-info">
        Your watchlist is empty. Visit the <a asp-controller="Home" asp-action="Index" class="link-primary link-empty-state">Search Page</a> to add trademarks to track.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm align-middle mb-2">
            <thead>
                <tr>
                    <th scope="col">Reg. No.</th>
                    <th scope="col">Wordmark</th>
                    <th scope="col">Added On</th>
                    <th scope="col">Initial Status</th>
                    <th scope="col">Current Status</th>
                    <th scope="col" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@(string.IsNullOrWhiteSpace(item.RegistrationNumber) ? "—" : item.RegistrationNumber)</td>

                        <td>
                            <a asp-controller="Trademarks"
                               asp-action="Details"
                               asp-route-id="@item.PublicId"
                               asp-route-returnUrl="@currentUrl"
                               class="link-body-emphasis text-decoration-none">
                                @item.Wordmark
                            </a>
                        </td>

                        <td>@(item.AddedOnDate?.ToLocalTime().ToString(DateTimeFormat, CultureInfo.InvariantCulture) ?? "—")</td>
                        <td>@(string.IsNullOrWhiteSpace(item.InitialStatus) ? "—" : item.InitialStatus)</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(item.CurrentStatus))
                            {
                                @item.CurrentStatus
                            }
                            else
                            {
                                @:—
                            }
                            @if (item.HasStatusChange)
                            {
                                <span class="ms-1" title="Status changed since added" aria-label="Status changed">⚡</span>
                            }
                        </td>
                        <td class="text-end">
                            <!-- Toggle notifications -->
                            <form asp-controller="Watchlist"
                                  asp-action="ToggleNotifications"
                                  method="post"
                                  class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="trademarkId" value="@item.Id" />
                                <input type="hidden" name="enabled" value="@(!item.NotificationsEnabled)" />
                                <input type="hidden" name="returnUrl" value="@currentUrl" />
                                <button type="submit" class="btn btn-outline-secondary btn-sm" title="Toggle notifications">
                                    @(item.NotificationsEnabled ? "🔔" : "🔕")
                                </button>
                            </form>

                            <!-- Trademark Details -->
                            <a class="btn btn-secondary btn-sm"
                               asp-controller="Trademarks"
                               asp-action="Details"
                               asp-route-id="@item.PublicId"
                               asp-route-returnUrl="@currentUrl">
                                Details
                            </a>

                            <!-- Remove from watchlist -->
                            <form asp-controller="Watchlist"
                                  asp-action="Remove"
                                  method="post"
                                  class="d-inline ms-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="trademarkId" value="@item.Id" />
                                <input type="hidden" name="returnUrl" value="@currentUrl" />
                                <button type="submit" class="btn btn-outline-danger btn-sm"
                                        onclick="return confirm('Remove this trademark from your watchlist?');">
                                    Remove
                                </button>
                            </form>

                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <p class="text-muted small mt-2">
        ⚡ indicates the trademark’s status changed since you added it.
    </p>
}
