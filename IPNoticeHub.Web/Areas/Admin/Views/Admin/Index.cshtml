@using System.Globalization
@using static IPNoticeHub.Shared.Constants.DateTimeFormats.DefaultDateTimeFormat
@model IPNoticeHub.Web.Models.AdminDashboard.AdminDashboardViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-4">
        <div>
            <h1 class="h3 fw-bold mb-0">Admin Dashboard (Demo Version)</h1>
            <p class="text-muted mb-0 small">System status and user management</p>
        </div>
        <div class="badge bg-light text-dark border fw-medium px-3 py-2 rounded-pill">
            <span class="text-success me-1">●</span> Live System
        </div>
    </div>

    <!-- Summary Stats -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="p-3 border rounded shadow-sm bg-white text-center">
                <div class="text-muted small text-uppercase fw-bold mb-1">Users</div>
                <div class="h3 mb-0">@Model.TotalUsers</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="p-3 border rounded shadow-sm bg-white text-center">
                <div class="text-muted small text-uppercase fw-bold mb-1">Trademarks</div>
                <div class="h3 mb-0">@Model.TrademarksAdded</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="p-3 border rounded shadow-sm bg-white text-center">
                <div class="text-muted small text-uppercase fw-bold mb-1">Copyrights</div>
                <div class="h3 mb-0">@Model.CopyrightsAdded</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="p-3 border rounded shadow-sm bg-white text-center">
                <div class="text-muted small text-uppercase fw-bold mb-1">Watchlist</div>
                <div class="h3 mb-0">@Model.WatchlistedItems</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Recent Registrations Table -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm border-top border-3">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-bold">Recent Registrations</h6>
                    
                </div>
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr class="small">
                               
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentRegistrations?.Any() == true)
                            {
                                @foreach (var user in Model.RecentRegistrations)
                                {
                                    <tr><td class="ps-3"><span class="fw-medium">@user.Email</span></td></tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="2" class="text-center py-4 text-muted">No recent activity.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- System Info Sidebar -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm border-top border-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3">System Info</h6>
                    <div class="mb-3">
                        <label class="small text-muted d-block">Database</label>
                        <span class="fw-medium">SQL (Azure SQL migration planned)</span>
                    </div>
                    <div class="mb-3">
                        <label class="small text-muted d-block">Auth Type</label>
                        <span class="fw-medium">Identity-based RBAC</span>
                    </div>
                    <hr>
                    <div class="small text-muted">
                        <i class="bi bi-info-circle-fill me-1"></i>
                        Current data represents seeded demo accounts.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
